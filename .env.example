# Optional AI module (Gemini 1.5 Flash via Google AI Studio).
# The key is read ONLY server-side by the Vercel Serverless Function at
# app/api/rewrite/route.ts and is never exposed to the browser.
# Get a free key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Optional: override the Gemini model (defaults to gemini-1.5-flash).
GEMINI_MODEL=gemini-1.5-flash

# Optional: simple per-IP rate limit for the proxy (requests per window).
RATE_LIMIT_MAX=20
RATE_LIMIT_WINDOW_MS=60000
